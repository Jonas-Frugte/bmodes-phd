\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jonasstyle}[2026/04/15 Clean modern LaTeX style for pdfLaTeX]

% --------------------------------------------------
% Font encoding and input
% --------------------------------------------------
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}

% --------------------------------------------------
% Modern-ish sans serif font for text
% --------------------------------------------------
\RequirePackage[default]{sourcesanspro}

% --------------------------------------------------
% Math font
% --------------------------------------------------
\RequirePackage{newtxmath}

% --------------------------------------------------
% Page layout (smaller margins)
% --------------------------------------------------
\RequirePackage[a4paper,margin=2.6cm]{geometry}

% --------------------------------------------------
% Typography improvements
% --------------------------------------------------
\RequirePackage{microtype}

% --------------------------------------------------
% Math / graphics
% --------------------------------------------------
\RequirePackage{amsmath,amssymb,bm}
\RequirePackage{graphicx}
\RequirePackage{xcolor}

% --------------------------------------------------
% Paragraph style
% --------------------------------------------------
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.55em}

% --------------------------------------------------
% Section titles
% --------------------------------------------------
\RequirePackage[explicit]{titlesec}
\RequirePackage[normalem]{ulem}

% Roman numerals for chapters
\renewcommand{\thechapter}{\Roman{chapter}}

% Chapter formatting:
% - no "Chapter" word
% - no horizontal line
% - Roman numeral + title on one line
% - slightly smaller than default
% - underlined title
\titleformat{\chapter}[hang]
  {\LARGE\bfseries}
  {\thechapter}
  {0.75em}
  {\LARGE\bfseries\uline{#1}}

\titlespacing*{\chapter}{0pt}{0pt}{1.2em}

\titleformat{\section}
  {\Large\bfseries}
  {\thesection}{0.75em}{#1}

\titleformat{\subsection}
  {\large\bfseries}
  {\thesubsection}{0.6em}{#1}

\titleformat{\subsubsection}
  {\normalsize\bfseries}
  {\thesubsubsection}{0.5em}{#1}

\titlespacing*{\section}{0pt}{1.4em}{0.6em}
\titlespacing*{\subsection}{0pt}{1.0em}{0.4em}
\titlespacing*{\subsubsection}{0pt}{0.8em}{0.3em}

% --------------------------------------------------
% Title styling
% --------------------------------------------------
\RequirePackage{titling}

\pretitle{\begin{center}\LARGE\bfseries}
\posttitle{\par\end{center}\vspace{0.5em}}

\preauthor{\begin{center}\normalsize}
\postauthor{\par\end{center}\vspace{0.25em}}

\predate{\begin{center}\small}
\postdate{\par\end{center}\vspace{1em}}

% --------------------------------------------------
% Captions
% --------------------------------------------------
\RequirePackage[font=small,labelfont=bf]{caption}

% --------------------------------------------------
% Lists
% --------------------------------------------------
\RequirePackage{enumitem}
\setlist{itemsep=0.25em, topsep=0.4em}

% --------------------------------------------------
% Hyperlinks
% --------------------------------------------------
\definecolor{linkcol}{RGB}{25,75,135}
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=linkcol,
    citecolor=linkcol,
    urlcolor=linkcol,
    pdfborder={0 0 0}
}

% --------------------------------------------------
% Header / footer
% --------------------------------------------------
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\rhead{\thepage}
\renewcommand{\headrulewidth}{0pt}

% --------------------------------------------------
% Slightly improved line spacing
% --------------------------------------------------
\linespread{1.03}

% --------------------------------------------------
% Make sans-serif the default document font
% --------------------------------------------------
\renewcommand{\familydefault}{\sfdefault}

% --------------------------------------------------
% Prevent blank pages before chapters in two-sided layouts
% --------------------------------------------------
\let\cleardoublepage\clearpage